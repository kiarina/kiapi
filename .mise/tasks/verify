#!/usr/bin/env bash
#MISE description="Run E2E verification (interactive, or scoped with flags)"
#
# All arguments are forwarded to scripts/verify.py. Run without arguments for an
# interactive (fzf) selection, or scope it, for example:
#
#   mise run verify --kiapi --family embedding --fast
#   mise run verify --kiapi-relay --relay local
#   mise run verify --kiapi-proxy --family chat --relay gcp
#
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$PROJECT_DIR"

exec uv run python scripts/verify.py "$@"
