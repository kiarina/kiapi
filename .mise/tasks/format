#!/usr/bin/env bash
#MISE description="Format and auto-fix lint issues (all, or a single [package])"
#USAGE arg "[package]" help="Package name (default: current package, or all at repo root)"
#USAGE flag "--unsafe" help="Apply Ruff unsafe fixes"

set -euo pipefail

target="${usage_package:-$(cd "${MISE_ORIGINAL_CWD:-$PWD}" && mise run package:current)}"
unsafe="${usage_unsafe:-false}"

format_paths() {
    local paths=("$@")
    local check_args=(check "${paths[@]}" --fix)
    [ "$unsafe" = "true" ] && check_args+=(--unsafe-fixes)
    uv run --group dev ruff "${check_args[@]}"
    uv run --group dev ruff format "${paths[@]}"
}

if [ "$target" = "all" ]; then
    while IFS= read -r package; do
        args=("$package")
        [ "$unsafe" = "true" ] && args+=(--unsafe)
        mise run format "${args[@]}"
    done < <(mise run package:list)
    format_paths scripts
    exit 0
fi

if [ ! -f "packages/$target/pyproject.toml" ]; then
    echo "❌ Package not found: $target" >&2
    exit 1
fi

paths=()
[ -d "packages/$target/src" ] && paths+=("packages/$target/src")
[ -d "packages/$target/tests" ] && paths+=("packages/$target/tests")
[ "${#paths[@]}" -eq 0 ] || format_paths "${paths[@]}"
