#!/usr/bin/env bash
#MISE description="Publish built distributions in dist/ to PyPI"
#USAGE arg "[package]" help="Package name for the index check URL / links (kiapi | kiapi-relay | kiapi-proxy)"
#USAGE flag "-t --test" help="Publish to TestPyPI instead of PyPI"

set -euo pipefail

test_pypi="${usage_test:-false}"
package="${usage_package:-}"

if [ "$test_pypi" = "true" ]; then
    echo "Publishing to TestPyPI..."
    if [ -n "$package" ]; then
        uv publish \
            --publish-url https://test.pypi.org/legacy/ \
            --check-url "https://test.pypi.org/simple/$package/" \
            dist/*
        echo "Package published to TestPyPI."
        echo "https://test.pypi.org/project/$package/"
    else
        uv publish --publish-url https://test.pypi.org/legacy/ dist/*
        echo "Packages published to TestPyPI."
    fi
else
    echo "Publishing to PyPI..."
    if [ -n "$package" ]; then
        uv publish --check-url "https://pypi.org/simple/$package/" dist/*
        echo "Package published to PyPI."
        echo "https://pypi.org/project/$package/"
    else
        uv publish dist/*
        echo "Packages published to PyPI."
    fi
fi
