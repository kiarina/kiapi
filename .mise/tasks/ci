#!/usr/bin/env bash
#MISE description="Run CI checks (setup, lint, test, generated artifacts, and build)"
#USAGE flag "--no-setup" help="Skip setup when the environment is already prepared"

set -euo pipefail

no_setup="${usage_no_setup:-false}"

if [ "$no_setup" = "false" ]; then
    mise run setup
fi

mise run lint
mise run test
make config
make pages
mise run build
