#!/usr/bin/env bash
#MISE description="Setup development environment (install tools, sync dependencies, and download test assets)"

set -euo pipefail

echo "🔧 Installing mise tools..."
mise install

echo "📦 Syncing workspace dependencies..."
# --inexact: keep out-of-band installs (e.g. `kiapi activate --family ltx2`'s
# mlx-video) that aren't in uv.lock. Use `make sync` for an exact reconcile.
uv sync --inexact --all-packages --all-extras --all-groups

echo "📥 Downloading test assets..."
mise run test-assets:download

echo "✅ Development environment setup complete!"
